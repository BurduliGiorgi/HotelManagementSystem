@model HotelManagementSystem.Models.Hotel

@{
    ViewData["Title"] = "Hotel Details";
}

<div class="container mt-5">
    <div class="card shadow-lg border-0 rounded-lg overflow-hidden">
        <div class="card-header bg-dark text-white text-center py-4">
            <h2 style="font-weight:bold" class="mb-0">@Model.Name</h2>
        </div>
        <div class="card-body p-5">
            <div class="text-center mb-4">
                <img src="@Html.DisplayFor(model => model.Logo_Url)" alt="@Model.Name" class="img-fluid rounded-circle shadow-lg" style="max-width: 200px; border: 5px solid #fff;" />
            </div>
            <div class="row">
                <div class="col-md-6">
                    <ul class="list-group list-group-flush">
                        <li style="font-weight:bold" class="list-group-item"><strong>Email:</strong>   @Model.Email</li>
                        <li style="font-weight:bold" class="list-group-item"><strong>Phone:</strong>  @Model.Phone</li>
                        <li style="font-weight:bold" class="list-group-item"><strong>Address:</strong> @Model.Address, @Model.City</li>
                    </ul>
                </div>
                <div class="col-md-6">
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item">
                            <strong>Status:</strong>
                            <span style="font-weight:bold" class="badge px-3 py-2" style="color: white; background-color: @(Model.Status == "Open" ? "#28a745" : "#dc3545")">
                                @Model.Status
                            </span>
                        </li>
                        <li style="font-weight:bold" class="list-group-item">
                            <strong>Stars:</strong>
                            @for (int i = 0; i < Model.Stars; i++)
                            {
                                <i class="fas fa-star text-warning"></i>
                            }
                        </li>
                        <li style="font-weight:bold" class="list-group-item"><strong>Check-in:</strong> @Model.CheckinTime</li>
                        <li style="font-weight:bold" class="list-group-item"><strong>Check-out:</strong> @Model.CheckoutTime</li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="card-footer bg-dark d-flex justify-content-between">
            <a asp-action="Index" class="btn btn-outline-light">
                <i style="font-weight:bold"class="fas fa-arrow-left"></i> Back to List
            </a>
        </div>
    </div>
</div>

<div class="container mt-5">
    <h3 class="text-center mb-4 text-dark">Hotel Staff</h3>
    <div class="table-responsive">
        <table class="table table-dark table-hover text-center rounded">
            <thead class="bg-primary text-white">
                <tr>
                    <th>First Name</th>
                    <th>Last Name</th>
                    <th>Email</th>
                    <th>Salary</th>
                    <th>Date of Birth</th>
                    <th>Phone</th>
                    <th>Hire Date</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var staff in Model.Staffs)
                {
                    <tr>
                        <td>@staff.FirstName</td>
                        <td>@staff.LastName</td>
                        <td>@staff.Email</td>
                        <td>@staff.Salary.ToString("C")</td>
                        <td>@staff.DateOfBirth.ToShortDateString()</td>
                        <td>@staff.Phone</td>
                        <td>@staff.HireDate.ToShortDateString()</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="https://kit.fontawesome.com/a076d05399.js" crossorigin="anonymous"></script>
}
